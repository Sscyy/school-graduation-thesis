# 表示作业的基本信息，自动填充，请勿修改
[base]
type = ml-easy-job

[resource]
usergroup = hadoop-ba-dealrank
queue = root.zw05_training_cluster.hadoop-recsys.serving

[roles]
workers = 1
worker.memory = 720000
worker.vcore = 120
worker.gcores80g = 8
worker.script = sh scripts/sam_mamba_train.sh

[am]
afo.app.am.resource.mb = 4096

[tensorboard]
with.tensor.board = false

[docker]
afo.docker.image.name = registry-offlinebiz.sankuai.com/custom_prod/com.sankuai.data.hadoop.gpu/hmart-waimaiad/training_cuda12.6_py310_glic2.32_torch2.8.0_fla2.8.3_re_vllm0.10.2_sglang_0.4.10_stable_fbe6cb8c:v2.0.0

afo.docker.rw.volume.paths = /mnt/dolphinfs/hdd_pool/docker/user/hadoop-ba-dealrank:/mnt/dolphinfs/hdd_pool/docker/user/hadoop-ba-dealrank

[data]
afo.data.prefetch=false

[failover]
afo.app.support.engine.failover=false

[others]
afo.app.name = sam_mamba_hovernet_train
afo.app.env.YARN_CONTAINER_RUNTIME_DOCKER_SHM_SIZE_BYTES = 34359738368
afo.xm.notice.receivers.account = suchenyan02

with_requirements = false
afo.use.acceleration.submission = true
